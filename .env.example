# Copy this file to .env and fill in the values
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_LOG_PASSWORD=false
HTTPS_ENABLED=false
REGENERATE_HTTPS_CERTS=false
# CN (Common Name) for generated self-signed certificate
HTTPS_CERT_CN=datavault.home
# Comma-separated extra hostnames/IPs to include in certificate SANs
# e.g. HTTPS_EXTRA_SANS=datavault.home,192.168.1.100,myserver.local
HTTPS_EXTRA_SANS=datavault.home

# Let's Encrypt configuration (for production domains only - requires public domain + port 80 open)
# Set to true to enable Let's Encrypt; if domain is not public, falls back to self-signed
LETSENCRYPT_ENABLED=true
# Your public domain name (must be resolvable from the internet)
LETSENCRYPT_DOMAIN=polydor415.synology.me
# Email for Let's Encrypt certificate expiry notifications
LETSENCRYPT_EMAIL=paul.mestrum@gmail.com
# Set to true to accept Let's Encrypt terms of service (required for LE)
LETSENCRYPT_AGREE_TOS=true

