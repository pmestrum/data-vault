# Copy this file to .env and fill in the values
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_LOG_PASSWORD=false
HTTPS_ENABLED=false
REGENERATE_HTTPS_CERTS=false
# CN (Common Name) for generated self-signed certificate
HTTPS_CERT_CN=datavault.home
# Comma-separated extra hostnames/IPs to include in certificate SANs
# e.g. HTTPS_EXTRA_SANS=datavault.home,192.168.1.100,myserver.local
HTTPS_EXTRA_SANS=datavault.home

